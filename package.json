{
  "name": "buykori-client-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "vercel-build": "vite build && node scripts/create-dashboard-route.cjs",
    "start": "node dist/server.cjs",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('server.js',{force:true})\"",
    "lint": "tsc --noEmit",
    "test:routing": "tsx --test src/lib/clientRoutes.test.ts",
    "test:analytics": "tsx --test src/services/analyticsApi.test.ts",
    "test:courier": "tsx --test src/services/courierApi.test.ts",
    "test:operations": "tsx --test src/services/operationsApi.test.ts",
    "test:account": "tsx --test src/services/accountApi.test.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "body-parser": "^1.20.6",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.546.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
