{
  "version": 2,
  "cleanUrls": true,
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/static/:path*",
      "destination": "https://api.buykori.app/static/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.buykori.app/api/:path*"
    },
    {
      "source": "/plugin/connect",
      "destination": "/index.html"
    },
    {
      "source": "/client/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/client/dashboard/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/order-success/:orderId",
      "destination": "/index.html"
    },
    {
      "source": "/client",
      "destination": "https://api.buykori.app/client"
    },
    {
      "source": "/client/:path*",
      "destination": "https://api.buykori.app/client/:path*"
    },
    {
      "source": "/((?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
