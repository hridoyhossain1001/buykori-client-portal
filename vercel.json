{
  "version": 2,
  "cleanUrls": true,
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.buykori.app/api/:path*"
    },
    {
      "source": "/client",
      "destination": "https://api.buykori.app/client"
    },
    {
      "source": "/client/:path*",
      "destination": "https://api.buykori.app/client/:path*"
    },
    {
      "source": "/((?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
